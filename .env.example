# GEOlocus Citation-Lift Study — environment template
# Real values live in C:/Users/ROBER/.secrets and are propagated by sync-secrets.sh.
# Never commit secrets — this file is the schema only.

# --- Database (Supabase) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Study config ---
STUDY_SEED=
STUDY_ID=geolocus_translation_layer_v0_1
LOG_SALT=

# --- v0.1 platforms (only Perplexity is wired for v0.1) ---
PERPLEXITY_API_KEY=

# --- v1 platforms (deferred until v0.1 gates pass) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# --- Browser collector infra (v1, not v0.1) ---
BROWSERBASE_API_KEY=
GOOGLE_ACCOUNT_PROFILE=
